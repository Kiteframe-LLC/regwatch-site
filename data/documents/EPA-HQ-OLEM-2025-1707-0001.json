      "page_count": 1,
      "representative_comment_id": "EPA-HQ-OLEM-2025-1707-0015",
      "representative_posted_date": "2026-03-13T04:00:00Z",
      "representative_length": 271,
      "representative_excerpt": "It is crucial that we keep the limitations stated in the Clean Water Act in order to continue supporting our wildlife and coastal communities. Hazardous substances and agricultural discharge must be monitored to protect drinking water, recreational water, and marshlands.",
      "submissions": {
        "EPA-HQ-OLEM-2025-1707-0015": {
          "organization": "",
          "postedDate": "2026-03-13T04:00:00Z",
          "zip": "",
